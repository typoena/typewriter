# Typoena installer — common commands.
# A plain (stable-toolchain) cargo crate; just sets cwd to installer/ so every
# recipe runs from here. `run` launches the interactive TUI wizard; the rest are
# the headless modes that need no TTY.

# list recipes
default:
    @just --list

# launch the interactive setup wizard (needs a TTY)
run:
    cargo run

# preflight checks + derived config, printed and exit (scriptable, no TTY)
check:
    cargo run -- --check

# list the removable cards the SD step would offer
list-cards:
    cargo run -- --list-cards

# exercise the clone + config-write path with no card: clones to a temp dir.
# usage: just dry-run <remote-url> [dest-dir] [--wipe]
dry-run remote *args:
    cargo run -- --dry-run-sd {{remote}} {{args}}

# reformat a removable card to a blank FAT32 volume. Headless: prints the target,
# asks once y/N, erases + ejects. Backs firmware's `just wipe`. Flags pass through:
#   --no-eject keep it mounted · -y skip the prompt · --ui full-screen TUI picker
# usage: just wipe [volume] [--label NAME] [--no-eject] [-y] [--ui]
wipe *args:
    cargo run -- --wipe {{args}}

# compile (release)
build:
    cargo build --release

# run the test suite
test:
    cargo test
