# Typoena firmware — common commands.
# Recipes source ~/export-esp.sh themselves (LIBCLANG_PATH + Xtensa GCC),
# so no per-shell setup is needed before calling just.

# Load firmware/.env (Wi-Fi creds for the network spikes) into recipe env.
# Absent .env is fine — the editor build ignores TW_* entirely.
set dotenv-load := true

esp_env := ". ~/export-esp.sh &&"
elf := "target/xtensa-esp32s3-espidf/release/firmware"
elf_wifi := "target/xtensa-esp32s3-espidf/release/wifi_tls"

# Production dual-OTA partition table (ota_0/ota_1/otadata) for `:update`.
# Applied by `flash-ota` — the one-time migration that makes a device OTA-capable.
partition_table_ota := justfile_directory() + "/partitions-ota.csv"

# Spike 7 Path 2 — env for the git2/libgit2 build. LIBGIT2_SRC points at the
# vendored libgit2 submodule (v1.9.4, matches libgit2-sys 0.18.5). pkgconfig/
# holds fake .pc files so libgit2-sys + libz-sys run in system mode and the
# symbols come from the esp-idf libgit2 component. Only the git recipes set this,
# so the editor build never compiles libgit2.
libgit2_src := justfile_directory() + "/components/libgit2/vendor"
git_env := "LIBGIT2_SRC=" + libgit2_src + " LIBGIT2_NO_VENDOR=1 PKG_CONFIG_ALLOW_CROSS=1 PKG_CONFIG_LIBDIR=" + justfile_directory() + "/pkgconfig"

# list recipes
default:
    @just --list

# compile (release) — THE product firmware: editor + EPD + USB + SD + git
# publishing (`:gp`/`:gl`) + `:update` OTA + onboarding wizard. Always the full
# build (compiles libgit2 + mbedTLS, links git2). Editor/render logic is
# host-tested off-device (`cargo test -p app -p editor`); after the first build
# libgit2 is a cached esp-idf component, so on-device rebuilds are incremental.
build:
    {{esp_env}} {{git_env}} cargo build --release --bin firmware --features full

# build + flash + open serial monitor (full firmware, see `build`)
flash:
    {{esp_env}} {{git_env}} cargo run --release --bin firmware --features full

# Reflashes onto the dual A/B layout (partitions-ota.csv) so `:update` has an
# inactive slot to write into — a single-slot device can't grow one while
# running, so this USB flash is the one manual step; every update after it is
# over the air. Also flashes OUR esp-idf bootloader (built with
# CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE) instead of espflash's prebuilt one, so a
# boot-looping OTA image auto-rolls-back; it falls back to espflash's bootloader
# (OTA works, rollback does NOT) with a loud warning if the built one isn't
# found. Switching layout rewrites flash, but notes live on the SD card
# (/sd/repo), not flash — untouched.
# ONE-TIME USB migration to the OTA A/B layout; every :update after is airborne.
flash-ota: build
    just _flash-prod-image yes no

# Shared flash body for flash-ota / ship: flash the ALREADY-BUILT firmware onto
# the dual A/B OTA layout, preferring OUR esp-idf bootloader (built with
# CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE, so a boot-looping OTA image rolls back)
# over espflash's prebuilt one. Args: monitor ("yes" stays attached to the serial
# log after flashing), require_rollback ("yes" REFUSES to flash without our
# bootloader — `ship` passes this so no field unit ships without rollback;
# flash-ota passes "no" and just warns). Hidden (leading `_`): callers run `build`.
_flash-prod-image monitor="no" require_rollback="no":
    #!/usr/bin/env bash
    set -euo pipefail
    boot=$(ls target/xtensa-esp32s3-espidf/release/build/esp-idf-sys-*/out/build/bootloader/bootloader.bin 2>/dev/null | head -1 || true)
    mon=""
    if [ "{{monitor}}" = "yes" ]; then mon="--monitor"; fi
    if [ -z "${boot:-}" ]; then
        if [ "{{require_rollback}}" = "yes" ]; then
            echo "error: rollback-enabled esp-idf bootloader not found — refusing to ship a unit" >&2
            echo "       without field rollback (a bad OTA could brick it with no USB nearby)." >&2
            echo "       Run \`just build\` so esp-idf-sys emits its bootloader, then retry." >&2
            exit 1
        fi
        echo "!! esp-idf bootloader.bin not found — flashing espflash's bootloader; OTA works but rollback will NOT."
        espflash flash $mon --baud 921600 --partition-table {{partition_table_ota}} --flash-size 16mb {{elf}}
    else
        echo "Using rollback-enabled bootloader: $boot"
        espflash flash $mon --baud 921600 --bootloader "$boot" --partition-table {{partition_table_ota}} --flash-size 16mb {{elf}}
    fi

# Prepare a CUSTOMER unit for shipping: flash the production OTA firmware over USB
# (dual A/B layout + our rollback bootloader, REQUIRED here unlike flash-ota),
# then print the remaining hands-on steps. No serial monitor — a unit is validated
# by eye on the e-ink panel (the first-boot wizard), so this returns as soon as
# the flash lands, ready for the next unit. Does NOT touch the SD card; that's a
# separate `just wipe` on a card reader.
# Flash a customer unit for shipping (OTA layout + REQUIRED rollback; card is separate).
ship: build
    just _flash-prod-image no yes
    @echo ""
    @echo "✅ firmware flashed — dual A/B OTA layout + rollback bootloader."
    @echo "Finish this unit (separate SD-card step, not done here):"
    @echo "  1. Insert a BLANK FAT32 card:  just wipe"
    @echo "  2. Power-cycle; confirm the first-boot WIZARD (Wi-Fi screen) paints on the panel."
    @echo "     (blank panel or boot loop? debug with: just monitor)"
    @echo "  3. Power off and box it. The customer sets their own Wi-Fi + GitHub on first"
    @echo "     boot; every firmware update after that rides over the air (:update)."

# Regenerate CHANGELOG.md from the git history with git-cliff, then sync it into
# the typoena-site repo so the /changelog page shows it. Two streams: firmware
# (all commits except installer/case/docs/tooling scopes) and installer (the
# macOS CLI). Version boundaries come from `firmware-v*` / `installer-v*` tags —
# `publish-firmware` tags a release before calling this, so new versions appear
# automatically. Safe to run standalone any time to refresh from current tags.
changelog:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v git-cliff >/dev/null || { echo "error: git-cliff required (brew install git-cliff)" >&2; exit 1; }
    root="{{justfile_directory()}}/.."
    site="$root/typoena-site"
    out="$root/CHANGELOG.md"
    cd "$root"
    {
        printf '%s\n' \
            '# Typoena changelog' \
            '' \
            'The Typoena firmware, release by release, newest first. Your device updates' \
            'itself over Wi-Fi — run `:update` to pull the latest build. The macOS setup' \
            'tool (the installer) is versioned separately and listed at the end.' \
            '' \
            '_Generated from the commit history with [git-cliff](https://git-cliff.org)._' \
            '' \
            '## Firmware' \
            ''
        git-cliff --config cliff.toml --tag-pattern 'firmware-v.*' 2>/dev/null
        printf '%s\n' \
            '' \
            '## Installer' \
            '' \
            'The macOS setup tool that prepares an SD card — install it with' \
            '`curl -fsSL https://typoena.dev/install.sh | sh`.' \
            ''
        git-cliff --config cliff.installer.toml --tag-pattern 'installer-v.*' --include-path 'installer/**' 2>/dev/null
    } > "$out"
    echo "wrote $out"
    if [ -d "$site/.git" ]; then cp "$out" "$site/src/changelog.md"; echo "synced → typoena-site/src/changelog.md"; fi

# Publish the current firmware as a Gitea release and point the update pointer at
# it. Builds the production image, converts the ELF to the app image the device
# streams into its inactive slot (espflash save-image → esp-idf app format), then:
#   1. uploads it to a Gitea release tagged `firmware-v<ver>` (via the `tea` CLI),
#   2. writes the 6-byte latest.txt into the site's public/firmware/, and
#   3. regenerates CHANGELOG.md (`just changelog`) so the site's /changelog page
#      and this release's notes both reflect the new version.
# The binary never touches git — only the version pointer + changelog on the site.
#
# The device (baked base https://typoena.dev/firmware) GETs latest.txt for the
# version, then requests typoena-<ver>.bin, which nginx 302-redirects to the Gitea
# release asset (see typoena-site/nginx.conf). The device resolves its version from
# latest.txt (never the repo's /releases/latest), so the tag is a plain release.
#
# <ver> comes from firmware/Cargo.toml (the device's FW_VERSION), so BUMP
# [package].version before publishing. Commit first for a reproducible release:
# the Gitea tag points at main's HEAD, but the image is built from the worktree.
# Needs the `tea` CLI logged in to git.apoena.dev (`tea logins list`).
# Publish the current firmware as a Gitea release + update the typoena.dev pointer.
publish-firmware: build
    #!/usr/bin/env bash
    set -euo pipefail
    ver="$(grep -m1 '^version[[:space:]]*=' "{{justfile_directory()}}/Cargo.toml" | sed -E 's/.*"([^"]+)".*/\1/')"
    [ -n "$ver" ] || { echo "error: couldn't read [package].version from firmware/Cargo.toml" >&2; exit 1; }
    command -v tea >/dev/null || { echo "error: the tea CLI is required (brew install tea; tea login add)" >&2; exit 1; }
    tag="firmware-v$ver"
    site="{{justfile_directory()}}/../typoena-site"
    [ -d "$site/.git" ] || { echo "error: typoena-site repo not found at $site" >&2; exit 1; }
    # Build the OTA app image into a scratch dir (never committed to the site).
    work="$(mktemp -d)"; trap 'rm -rf "$work"' EXIT
    bin="$work/typoena-$ver.bin"
    echo "generating OTA app image for $ver → $(basename "$bin")"
    espflash save-image --chip esp32s3 "{{elf}}" "$bin"
    # Tag this release locally so git-cliff attributes the new commits to $ver,
    # then regenerate CHANGELOG.md and sync it into the site. tea creates the
    # matching tag on Gitea below; this local tag is what the changelog reads.
    git tag -f "$tag" HEAD >/dev/null
    just changelog
    # Release note = this version's section from the regenerated CHANGELOG.md.
    # Falls back to a one-liner if the section is missing.
    changelog="{{justfile_directory()}}/../CHANGELOG.md"
    note="Over-the-air firmware image for Typoena $ver."
    section="$(awk -v ver="$ver" '
        /^## / { infw = ($0 == "## Firmware") }
        infw && $0 ~ ("^### \\[" ver "\\]") { grab = 1; next }
        grab && (/^### \[/ || /^## /) { exit }
        grab { print }
    ' "$changelog" | sed -e '/./,$!d')"
    [ -n "$section" ] && note="$(printf 'Typoena firmware v%s\n\n%s' "$ver" "$section")"
    # Create the Gitea release + upload the asset. `if !` so a duplicate tag gives
    # guidance instead of a bare failure — and latest.txt is only bumped on success.
    echo "creating Gitea release $tag …"
    if ! tea release create --repo typoena/typewriter --login julien \
        --tag "$tag" --title "Typoena firmware v$ver" \
        --note "$note" \
        --asset "$bin"; then
        echo "error: could not create release $tag (already exists?). To replace it:" >&2
        echo "       tea release delete --repo typoena/typewriter --login julien $tag" >&2
        echo "       or bump firmware/Cargo.toml for a new version." >&2
        exit 1
    fi
    # Point the device's update pointer at this version (tiny file, stays on site).
    dir="$site/public/firmware"; mkdir -p "$dir"
    printf '%s\n' "$ver" > "$dir/latest.txt"
    echo ""
    echo "✅ published $tag to Gitea, set latest.txt = $ver, and regenerated the changelog"
    echo "deploy the pointer + changelog (the device won't see $ver until this ships):"
    echo "  git -C \"$site\" add public/firmware/latest.txt src/changelog.md && git -C \"$site\" commit -m \"firmware: release $ver\" && git -C \"$site\" push"

